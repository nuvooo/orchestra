# Orchestra server configuration

# Port the API listens on (default 8787)
PORT=8787

# SQLite database file (default ./orchestra.db, relative to server/)
DATABASE_FILE=./orchestra.db

# --- Real KI agents (Claude API) ---
# Required for agents to actually run tickets. Without it, the run endpoint
# returns a clear "not configured" message and the app stays a click-through demo.
ANTHROPIC_API_KEY=
# Optional: default model for agent runs (default claude-opus-4-8)
ORCHESTRA_MODEL=claude-opus-4-8

# --- Integrations ---
# Jira and Slack credentials are stored per-project via the app UI
# (Projekt-Einstellungen). These env vars are only fallbacks / defaults.
# Jira: an API token from https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_EMAIL=
JIRA_API_TOKEN=
# Slack: a bot token (xoxb-...) with chat:write scope
SLACK_BOT_TOKEN=
